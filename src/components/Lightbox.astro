---
import "photoswipe/style.css";
---

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";

  let lightbox: any;

  document.addEventListener('astro:page-load', () => {
    if (lightbox) {
      try {
        lightbox.destroy();
      } catch (e) {}
    }

    lightbox = new PhotoSwipeLightbox({
      gallery: "#gallery",
      children: "a",
      pswpModule: PhotoSwipe,
      bgOpacity: 1.0,
      paddingFn: (viewportSize) => {
        // Responsive padding
        if (viewportSize.x < 1024) {
          // Mobile/Tablet: standard padding
          return { top: 60, bottom: 60, left: 20, right: 20 };
        } else {
          // Desktop: Offset left by adding large right padding for caption
          const rightPadding = Math.min(450, viewportSize.x * 0.3);
          return { top: 80, bottom: 80, left: 80, right: rightPadding };
        }
      },
      loop: false,
      closeSVG: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>',
      zoomSVG: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>',
      arrowPrevSVG: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>',
      arrowNextSVG: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>',
    });

  lightbox.on("uiRegister", function () {
    const pswp = lightbox.pswp;
    if (!pswp || !pswp.ui) return;

    // Custom Caption on the right with Metadata
    pswp.ui.registerElement({
      name: "custom-caption",
      appendTo: "root",
      onInit: (el, pswpInstance) => {
        el.className = "pswp__custom-caption";
        pswpInstance.on("change", () => {
          const currSlide = pswpInstance.currSlide;
          if (currSlide && currSlide.data.element) {
            const img = currSlide.data.element.querySelector("img");
            const exifJson = currSlide.data.element.dataset.exif;
            
            if (img) {
              const title = img.getAttribute("alt") || "";
              const cleanTitle = title.replace(/\.[^/.]+$/, "").replace(/[_-]/g, " ");
              
              let metaHtml = "";
              if (exifJson) {
                try {
                  const exif = JSON.parse(exifJson);
                  
                  // Format Date
                  let dateStr = "";
                  if (exif.date) {
                    const parts = exif.date.split(" ");
                    if (parts.length >= 1) {
                      dateStr = parts[0].replace(/:/g, "/");
                    }
                  }

                  const settings = `${exif.iso ? `ISO ${exif.iso}` : ""} ${exif.fNumber ? ` · ${exif.fNumber}` : ""} ${exif.exposure ? ` · ${exif.exposure}` : ""}`.trim();

                  if (dateStr || settings || (exif.gps && exif.gps.lat)) {
                    metaHtml = `
                      <div class="caption-metadata">
                        ${dateStr ? `<div class="meta-item"><span class="label">Date</span><span class="value">${dateStr}</span></div>` : ""}
                        ${exif.gps && exif.gps.lat ? `<div class="meta-item loc-container"><span class="label">Location</span><span class="value loc-val" data-lat="${exif.gps.lat}" data-lon="${exif.gps.lon}">Loading location...</span></div>` : ""}
                        ${settings ? `
                        <div class="meta-item">
                          <span class="label">Settings</span>
                          <span class="value">${settings}</span>
                        </div>` : ""}
                      </div>
                    `;
                  }
                } catch (e) {
                  console.error("Error parsing EXIF", e);
                }
              }

              el.innerHTML = `
                <div class="caption-content">
                  <h2 class="caption-title">${cleanTitle}</h2>
                  ${metaHtml}
                </div>
              `;

              // Trigger Reverse Geocoding
              const locEl = el.querySelector(".loc-val");
              if (locEl) {
                const lat = locEl.getAttribute("data-lat");
                const lon = locEl.getAttribute("data-lon");
                if (lat && lon && lat !== "NaN" && lon !== "NaN") {
                  const cacheKey = `geo:${lat},${lon}`;
                  const cached = sessionStorage.getItem(cacheKey);
                  
                  const handleLocationResult = (name) => {
                    if (name === "Unknown Location") {
                      const container = locEl.closest(".loc-container");
                      if (container) (container as HTMLElement).style.display = "none";
                    } else {
                      locEl.textContent = name;
                    }
                  };

                  if (cached) {
                    handleLocationResult(cached);
                  } else {
                    fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=10`)
                      .then(res => res.json())
                      .then(data => {
                        let locationName = "Unknown Location";
                        if (data.address) {
                          const city = data.address.city || data.address.town || data.address.village || data.address.county;
                          const country = data.address.country;
                          locationName = city && country ? `${city}, ${country}` : (country || data.display_name.split(",")[0]);
                        }
                        handleLocationResult(locationName);
                        sessionStorage.setItem(cacheKey, locationName);
                      })
                      .catch(() => { handleLocationResult("Unknown Location"); });
                  }
                }
              }
            }
          }
        });
      },
    });

    pswp.ui.registerElement({
      name: "map-btn",
      order: 8,
      isButton: true,
      tagName: "button",
      html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>',
      onClick: (event, el, pswpInstance) => {
        const currSlide = pswpInstance.currSlide;
        if (currSlide && currSlide.data.element) {
          const exifJson = currSlide.data.element.dataset.exif;
          if (exifJson) {
            try {
              const exif = JSON.parse(exifJson);
              if (exif.gps && exif.gps.lat && exif.gps.lon) {
                window.open(`https://www.google.com/maps/search/?api=1&query=${exif.gps.lat},${exif.gps.lon}`, "_blank");
              }
            } catch (e) { console.error("Error opening map", e); }
          }
        }
      },
    });

    pswp.ui.registerElement({
      name: "share-btn",
      order: 9,
      isButton: true,
      tagName: "button",
      html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>',
      onClick: (event, el, pswpInstance) => {
        const url = window.location.href;
        if (navigator.share) {
          navigator.share({
            title: document.title,
            url: url
          }).catch((e) => {
            console.error("Error sharing", e);
          });
        } else {
          navigator.clipboard.writeText(url).then(() => {
            alert("Link copied to clipboard!");
          });
        }
      },
    });

    // Handle visibility of map button based on GPS data
    pswp.on("change", () => {
      const currSlide = pswp.currSlide;
      const mapBtn = document.querySelector(".pswp__button--map-btn");
      if (mapBtn) {
        let hasGps = false;
        if (currSlide && currSlide.data.element) {
          const exifJson = currSlide.data.element.dataset.exif;
          if (exifJson) {
            try {
              const exif = JSON.parse(exifJson);
              hasGps = !!(exif.gps && exif.gps.lat && exif.gps.lon);
            } catch (e) {}
          }
        }
        (mapBtn as HTMLElement).style.display = hasGps ? "block" : "none";
      }
    });
  });

  lightbox.init();
  });
</script>
